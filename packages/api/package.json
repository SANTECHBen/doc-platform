{
  "name": "@platform/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "dev:worker": "tsx watch --env-file=../../.env src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "tsx src/migrate-on-boot.ts && tsx src/server.ts",
    "start:worker": "tsx src/worker.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/lib-storage": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/sensible": "^6.0.4",
    "@mux/mux-node": "^14.0.1",
    "@platform/ai": "workspace:*",
    "@platform/db": "workspace:*",
    "@platform/shared": "workspace:*",
    "@sentry/node": "^10.52.0",
    "drizzle-orm": "^0.35.3",
    "fastify": "^5.6.0",
    "fastify-type-provider-zod": "^4.0.2",
    "file-type": "^22.0.1",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.14.0",
    "postgres": "^3.4.9",
    "sharp": "^0.34.5",
    "tsx": "^4.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.5",
    "typescript": "^5.6.3"
  }
}
