# --- Database ---
# PostgreSQL with pgvector extension enabled
DATABASE_URL=postgres://postgres:postgres@localhost:5432/doc_platform

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7
EMBEDDING_MODEL=voyage-3

# --- Auth (WorkOS) ---
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# --- Object storage (S3-compatible) ---
S3_ENDPOINT=
S3_BUCKET=doc-platform-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# --- Video ---
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- API server ---
API_PORT=3001
API_HOST=0.0.0.0
PUBLIC_PWA_ORIGIN=http://localhost:3000
PUBLIC_ADMIN_ORIGIN=http://localhost:3002
