{
  "name": "doc-platform",
  "version": "0.0.1",
  "private": true,
  "description": "Equipment-centric Connected Worker Platform for Material Handling & Industrial Automation",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @platform/db generate",
    "db:migrate": "pnpm --filter @platform/db migrate",
    "db:seed": "pnpm --filter @platform/db seed",
    "db:prepare-ai": "pnpm --filter @platform/db prepare-ai",
    "db:studio": "pnpm --filter @platform/db studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3",
    "@types/node": "^22.7.5"
  }
}
